# ─── Martijnfit environment variables ────────────────────────────────
# Copy to .env.local for local dev, and add the same keys in Vercel
# (Project → Settings → Environment Variables). NEVER commit .env.local.

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, keep secret

# Public site URL (used for OAuth redirects). Locally: http://localhost:3000
# In production set to your Vercel URL, e.g. https://martijnfit.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google OAuth — OPTIONAL. Login uses email magic-links, so leave these blank.
# Only needed if you later add the "Connect Google Calendar" feature.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Strava — https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret

# Anthropic (AI coach) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
